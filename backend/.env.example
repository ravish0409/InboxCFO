# Copy to backend/.env and fill in. Everything below is OPTIONAL:
# with no key the app runs fully on seed data (dashboard + Action Center); only live
# chat and live extraction need an LLM, and they fail cleanly with a 503 when it's off.

# --- LLM (unified config, spec §3A.1) -------------------------------------------------
# Provider: gemini | fireworks | off   (default: off)
LLM_PROVIDER=off
# Optional overrides — if empty, the per-provider defaults below are used.
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Agent tool-calling mode: "native" (OpenAI-style tools) or "json" (ReAct fallback)
AGENT_TOOL_MODE=native

# Cap outgoing LLM requests/minute to stay under the provider's RPM limit (free-tier
# Gemini is 5-15 RPM). Set a bit below your model's cap; 0 disables. Ingestion makes one
# call per document, so this paces bulk uploads / Gmail syncs instead of getting 429'd.
LLM_MAX_RPM=14

# --- Per-provider defaults (used when LLM_* overrides above are empty) -----------------
# Gemini uses Google's OpenAI-compatible endpoint, so the same `openai` client works.
# Set LLM_PROVIDER=gemini and either LLM_API_KEY or GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3.5-flash

# Set LLM_PROVIDER=fireworks and either LLM_API_KEY or FIREWORKS_API_KEY.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Model must support function calling for native tool mode.
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# --- Gmail sync (optional — app works without it via file upload / seed data) ---------
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_MAX_MESSAGES=40

# --- Database -------------------------------------------------------------------------
# DB_PATH is relative to backend/ (or absolute). DATABASE_URL overrides it if set.
DB_PATH=data.db

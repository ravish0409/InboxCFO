# Serves the built SPA and reverse-proxies the API. ${BACKEND_ORIGIN} is substituted
# from the environment at container start (nginx envsubst on /etc/nginx/templates/*).
server {
    # ${PORT} is substituted at container start. Locally it defaults to 80 (Dockerfile
    # ENV); on Render (and similar PaaS) the platform injects its own PORT and we honor it.
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # PDFs / .eml uploads can be a few MB — don't let nginx reject them.
    client_max_body_size 25m;

    # SPA routing: unknown paths fall back to index.html.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API + SSE streaming endpoints. Buffering off so /api/*/stream and /api/chat/stream
    # flush token-by-token; long read timeout so slow LLM turns don't get cut off.
    location /api/ {
        proxy_pass ${BACKEND_ORIGIN};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}

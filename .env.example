# Root compose config — copy to `.env` (next to docker-compose.yml). All optional.
#
# This file wires the SERVICES together. The backend's own app config (LLM keys, Gmail,
# DB) lives separately in backend/.env — see backend/.env.example.

# Host port the app is served on -> open http://localhost:<FRONTEND_PORT>
FRONTEND_PORT=8080

# Where the frontend (nginx) proxies /api. Defaults to the backend service on the compose
# network. Change ONLY for a split deploy where the API runs elsewhere, e.g.
#   BACKEND_ORIGIN=https://api.your-domain.com
BACKEND_ORIGIN=http://backend:8787

# Set to 1 to load demo/seed data the first time the DB volume is empty (seed.py wipes
# the DB, so it only runs when there's no existing data). Leave 0 for a clean start.
SEED_ON_START=0
